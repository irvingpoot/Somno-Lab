---

/**
 * @component ReturnButton
 * @description Enlace de navegación para regresar a la vista anterior o superior.
 * * CASO DE USO:
 * - Se ubica en la parte superior de formularios y vistas de detalle (ej: 'Ver Paciente', 'Editar Cita').
 * - Proporciona una salida segura si el usuario entró por error a una sección.
 * * DISEÑO:
 * - Estilo minimalista (texto gris que se ilumina al hover) con icono de flecha.
 * - Jerarquía visual baja para no competir con los botones de acción principales (Guardar).
 * * PROPS:
 * @prop {string} href - La ruta de destino (ej: '/lista', '/dashboard').
 * @prop {string} [text='Volver'] - Etiqueta del enlace.
 */

interface Props {
	href: string;
	text?: string;
}

const { href, text = "Volver" } = Astro.props;
---

<a href={href} class="fixed top-4 left-4 md:top-8 md:left-8 z-50 flex items-center gap-2 text-slate-500 hover:text-somno-dark transition-colors group">

    <div class="p-2 rounded-full bg-white/80 backdrop-blur-md border border-slate-200 
                group-hover:bg-somno-light/20 
                group-hover:border-somno-light/40 
                transition-all shadow-sm">
        
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
    </div>
    
    <span class="text-sm font-medium hidden md:block opacity-0 -translate-x-2 
                group-hover:opacity-100 group-hover:translate-x-0 
                transition-all duration-300 
                bg-white/90 backdrop-blur 
                text-slate-700
                px-3 py-1 rounded-full border border-slate-200 
                group-hover:border-somno-light/40">
        {text}
    </span>
</a>