---
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/login');

const { courseSlug, lessonSlug } = Astro.params;

// 1. Consultar Curso + Módulos + Lecciones
const { data: course } = await supabase
    .from('courses')
    .select(`
        *,
        modules (
        id, title, order_index,
        lessons (id, title, slug, video_url, duration, order_index, content_text)
        )
    `)
    .eq('slug', courseSlug)
    .single();

if (!course) return Astro.redirect('/404');

// 2. Verificar Inscripción
const { data: enrollment } = await supabase
    .from('enrollments')
    .select('id').eq('user_id', userId).eq('course_id', course.id).single();

if (!enrollment) return Astro.redirect(`/cursos/${courseSlug}`);

// 3. CONSULTAR PROGRESO DEL USUARIO
// Traemos todos los IDs de lecciones completadas por este usuario
const { data: userProgress } = await supabase
    .from('progress')
    .select('lesson_id')
    .eq('user_id', userId)
    .eq('is_completed', true);

// Convertimos a un Set para búsqueda rápida (O(1))
const completedLessonIds = new Set(userProgress?.map(p => p.lesson_id));

// 4. Ordenar y preparar datos
const sortedModules = course.modules.sort((a, b) => a.order_index - b.order_index);
let totalLessons = 0;
sortedModules.forEach(mod => {
    mod.lessons.sort((a, b) => a.order_index - b.order_index);
    totalLessons += mod.lessons.length;
});

// Calcular porcentaje
const completedCount = completedLessonIds.size;
const progressPercentage = totalLessons > 0 ? Math.round((completedCount / totalLessons) * 100) : 0;

// 5. Encontrar lección activa y siguiente
let activeLesson = null;
let nextLessonUrl = null;

for (let i = 0; i < sortedModules.length; i++) {
    const mod = sortedModules[i];
    for (let j = 0; j < mod.lessons.length; j++) {
        const lesson = mod.lessons[j];
        if (lesson.slug === lessonSlug) {
            activeLesson = lesson;
            // Lógica Siguiente Lección
            if (mod.lessons[j + 1]) {
                nextLessonUrl = `/aula/${courseSlug}/${mod.lessons[j + 1].slug}`;
            } else if (sortedModules[i + 1]?.lessons[0]) {
                nextLessonUrl = `/aula/${courseSlug}/${sortedModules[i + 1].lessons[0].slug}`;
            }
            break;
        }
    }
}

if (!activeLesson) return Astro.redirect('/404');

const isCompleted = completedLessonIds.has(activeLesson.id);

// Helper YouTube
const getYoutubeId = (url) => {
    if (!url) return null;
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : url;
};
const videoId = getYoutubeId(activeLesson.video_url);
---

<Layout title={`${activeLesson.title} - ${course.title}`}>
    
    <div class="flex flex-col lg:flex-row min-h-screen bg-slate-50">
        
        <aside class="w-full lg:w-80 bg-white border-r border-slate-200 flex flex-col h-auto lg:h-screen sticky top-0 z-20 overflow-y-auto">
            <div class="p-4 border-b border-slate-100 bg-white sticky top-0 z-10">
                <a href="/mis-cursos" class="text-xs text-slate-400 hover:text-somno mb-2 block">
                    <i class="fas fa-arrow-left mr-1"></i> Volver
                </a>
                <h2 class="font-bold text-slate-800 leading-tight">{course.title}</h2>
                
                <div class="mt-3 w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                    <div class="bg-somno h-1.5 rounded-full transition-all duration-500" style={`width: ${progressPercentage}%`}></div>
                </div>
                <p class="text-xs text-slate-400 mt-1 flex justify-between">
                    <span>{progressPercentage}% completado</span>
                    <span>{completedCount}/{totalLessons}</span>
                </p>
            </div>

            <div class="flex-1 overflow-y-auto">
                {sortedModules.map((modulo, index) => (
                    <div class="border-b border-slate-50">
                        <div class="px-4 py-3 bg-slate-50/50 font-bold text-xs text-slate-500 uppercase tracking-wider sticky top-0">
                            Módulo {index + 1}: {modulo.title}
                        </div>
                        
                        <div>
                            {modulo.lessons.map((leccion) => {
                                const isActive = leccion.slug === lessonSlug;
                                const isDone = completedLessonIds.has(leccion.id);
                                
                                return (
                                    <a 
                                        href={`/aula/${courseSlug}/${leccion.slug}`} 
                                        class={`flex items-start gap-3 px-4 py-3 text-sm transition-colors border-l-4 group ${
                                            isActive 
                                            ? 'bg-blue-50 border-somno text-slate-900 font-medium' 
                                            : 'border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900'
                                        }`}
                                    >
                                        <div class="mt-0.5 min-w-4">
                                            {/* LOGICA DE ICONOS: Activo vs Completado vs Pendiente */}
                                            {isActive ? (
                                                <i class="fas fa-play-circle text-somno animate-pulse"></i>
                                            ) : isDone ? (
                                                <i class="fas fa-check-circle text-green-500"></i>
                                            ) : (
                                                <i class="far fa-circle text-slate-300 text-xs group-hover:text-slate-400"></i>
                                            )}
                                        </div>
                                        <span class={`leading-snug ${isDone && !isActive ? 'text-slate-400 line-through decoration-slate-300' : ''}`}>
                                            {leccion.title}
                                        </span>
                                        <span class="ml-auto text-xs text-slate-400">{leccion.duration}m</span>
                                    </a>
                                );
                            })}
                        </div>
                    </div>
                ))}
            </div>
        </aside>

        <main class="flex-1 flex flex-col h-screen overflow-y-auto">
            <div class="bg-black w-full aspect-video shadow-lg relative z-10">
                {videoId ? (
                    <iframe 
                        class="w-full h-full"
                        src={`https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1`} 
                        title={activeLesson.title}
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen
                    ></iframe>
                ) : (
                    <div class="w-full h-full flex items-center justify-center text-white/50 flex-col gap-4">
                        <i class="fas fa-video-slash text-4xl"></i>
                        <p>No hay video disponible.</p>
                    </div>
                )}
            </div>

            <div class="max-w-4xl mx-auto w-full p-6 lg:p-10 space-y-8">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b border-slate-200 pb-6">
                    <div>
                        <h1 class="text-2xl lg:text-3xl font-bold text-slate-800 mb-2">
                            {activeLesson.title}
                        </h1>
                        <p class="text-slate-500">
                            Lección {activeLesson.order_index} del curso {course.title}
                        </p>
                    </div>
                    
                    <button 
                        id="btn-complete"
                        data-lesson-id={activeLesson.id}
                        data-is-completed={isCompleted}
                        class={`px-6 py-3 rounded-lg font-bold transition-all flex items-center gap-2 border shadow-sm ${
                            isCompleted 
                            ? 'bg-green-100 text-green-700 border-green-200 cursor-default' 
                            : 'bg-white hover:bg-slate-50 text-slate-600 border-slate-200 hover:border-somno hover:text-somno'
                        }`}
                    >
                        <i class={`fas ${isCompleted ? 'fa-check-double' : 'fa-check'}`}></i>
                        {isCompleted ? 'Completada' : 'Marcar como Visto'}
                    </button>
                </div>

                <div class="prose prose-slate max-w-none">
                    {activeLesson.content_text ? (
                        <p>{activeLesson.content_text}</p>
                    ) : (
                        <p class="text-slate-400 italic">No hay descripción adicional.</p>
                    )}
                </div>

                <div class="flex justify-between pt-10 mt-10 border-t border-slate-100">
                    <button class="text-slate-400 hover:text-slate-700 font-medium flex items-center gap-2 cursor-not-allowed opacity-50">
                        <i class="fas fa-chevron-left"></i> Anterior
                    </button>

                    {nextLessonUrl ? (
                        <a href={nextLessonUrl} class="bg-somno text-white px-6 py-3 rounded-lg font-bold hover:bg-teal-700 transition-colors flex items-center gap-2 shadow-lg shadow-somno/20">
                            Siguiente Lección <i class="fas fa-chevron-right"></i>
                        </a>
                    ) : (
                        <span class="text-slate-400 font-medium">¡Has terminado el curso! 🎉</span>
                    )}
                </div>
            </div>
        </main>
    </div>
</Layout>

<script>
    // LÓGICA DEL CLIENTE PARA COMPLETAR LECCIÓN
    const btnComplete = document.getElementById('btn-complete');

    if (btnComplete) {
        btnComplete.addEventListener('click', async () => {
            // Si ya está completada, no hacemos nada (o podrías implementar desmarcar)
            if (btnComplete.dataset.isCompleted === 'true') return;

            const lessonId = btnComplete.dataset.lessonId;
            const originalHTML = btnComplete.innerHTML;
            
            // Estado de carga visual
            btnComplete.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
            btnComplete.setAttribute('disabled', 'true');

            try {
                const response = await fetch('/api/progress', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lessonId }),
                });

                if (response.ok) {
                    // Éxito visual: Cambiar botón a verde y check doble
                    btnComplete.innerHTML = '<i class="fas fa-check-double"></i> Completada';
                    btnComplete.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
                    btnComplete.classList.add('bg-green-100', 'text-green-700', 'border-green-200');
                    btnComplete.dataset.isCompleted = 'true';
                    
                    // Opcional: Recargar el sidebar para ver el check verde (o recargar página)
                    // window.location.reload(); // Descomenta si quieres recargar para ver el cambio en el sidebar
                } else {
                    throw new Error('Error al guardar');
                }
            } catch (error) {
                console.error(error);
                btnComplete.innerHTML = originalHTML;
                btnComplete.removeAttribute('disabled');
                alert('No se pudo guardar el progreso.');
            }
        });
    }
</script>

<style>
    aside::-webkit-scrollbar { width: 6px; }
    aside::-webkit-scrollbar-track { background: #f1f5f9; }
    aside::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
</style>