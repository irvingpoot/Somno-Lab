---
// src/pages/aula/[courseSlug]/index.astro
import { supabase } from '../../../lib/supabase';

const { courseSlug } = Astro.params;
const { userId } = Astro.locals.auth();

if (!userId) return Astro.redirect('/login');

// 1. Buscamos el curso y sus módulos para encontrar la primera lección
const { data: course } = await supabase
    .from('courses')
    .select(`
        id,
        modules (
        order_index,
        lessons (slug, order_index)
        )
    `)
    .eq('slug', courseSlug)
    .single();

if (!course) return Astro.redirect('/404');

// 2. Verificar Inscripción (Seguridad)
const { data: enrollment } = await supabase
    .from('enrollments')
    .select('id').eq('user_id', userId).eq('course_id', course.id).single();

if (!enrollment) return Astro.redirect(`/cursos/${courseSlug}`);

// 3. Lógica para encontrar la lección #1
// Ordenamos para asegurar que sea la primera real
const firstModule = course.modules.sort((a, b) => a.order_index - b.order_index)[0];
const firstLesson = firstModule?.lessons.sort((a, b) => a.order_index - b.order_index)[0];

if (firstLesson) {
    return Astro.redirect(`/aula/${courseSlug}/${firstLesson.slug}`);
} else {
    return Astro.redirect('/404'); // Curso vacío
}
---