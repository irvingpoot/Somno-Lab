---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;

// 1. OBTENER EL CURSO ACTUAL (Ahora trae las nuevas columnas automágicamente)
const { data: dbCourse, error } = await supabase
    .from('courses')
    .select(`
        *,
        modules (
        id, title, order_index,
        lessons (id, duration)
        )
    `)
    .eq('slug', slug)
    .single();

if (!dbCourse) return Astro.redirect('/404');

// 2. OBTENER CURSOS RELACIONADOS
const { data: relatedDbCourses } = await supabase
    .from('courses')
    .select('*')
    .neq('id', dbCourse.id)
    .eq('is_published', true)
    .limit(3);

// --- LÓGICA DE UI ---
const totalLessons = dbCourse.modules ? dbCourse.modules.reduce((acc, m) => acc + m.lessons.length, 0) : 0;
const totalDurationMin = dbCourse.modules ? dbCourse.modules.reduce((acc, m) => acc + m.lessons.reduce((lAcc, l) => lAcc + l.duration, 0), 0) : 0;

// Formato de tiempo (ej: 2h 15m)
const hours = Math.floor(totalDurationMin / 60);
const mins = totalDurationMin % 60;
const durationString = hours > 0 
    ? `${hours}h ${mins > 0 ? mins + 'm' : ''}` 
    : `${mins} min`;

// Mapeo simple para la UI (Supabase ya nos da los arrays listos)
const course = {
    ...dbCourse,
    // Si algún campo viene vacío de la DB, ponemos un default para que no se rompa el diseño
    subtitle: dbCourse.subtitle || dbCourse.description, 
    learningPoints: dbCourse.learning_points || [],
    requirements: dbCourse.requirements || [],
    duration: durationString,
    totalLessons: totalLessons
};

// Features del Sidebar
const features = [
    { icon: 'video', label: 'Lecciones', value: `${totalLessons} videos` },
    { icon: 'clock', label: 'Duración', value: durationString },
    { icon: 'level', label: 'Nivel', value: dbCourse.level },
    { icon: 'lang', label: 'Idioma', value: dbCourse.language },
    { icon: 'cert', label: 'Certificado', value: dbCourse.has_certificate ? 'Sí' : 'No' },
];
---

<Layout title={course.title}>
    <Navbar />

    <section class="w-full pt-32 pb-12 px-4 border-b border-slate-100">
        <div class="max-w-4xl mx-auto text-center">
            
            <span class="inline-block bg-somno/10 text-somno px-4 py-1.5 rounded-lg text-sm font-bold tracking-wide mb-6 uppercase">
                {course.category}
            </span>
        
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 leading-tight mb-6">
                {course.title}
            </h1>
        
            <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
                {course.subtitle}
            </p>
        
            <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-16">
                <button class="flex items-center gap-2 bg-slate-900 hover:bg-somno text-white px-8 py-4 rounded-xl font-bold transition-all hover:scale-105 active:scale-95 shadow-xl shadow-slate-200">
                    Inscribirse por {course.price === 0 ? 'GRATIS' : `$${course.price}`}
                </button>
        
                <a href="#temario" class="bg-slate-100 hover:bg-slate-200 text-slate-700 px-8 py-4 rounded-xl font-bold transition-all hover:scale-105 active:scale-95">
                    Ver Temario
                </a>
            </div>
        
            <div class="flex flex-col md:flex-row justify-center items-center gap-8 md:gap-12 md:divide-x divide-slate-200">
                <div class="flex items-center gap-4 px-4 w-full md:w-auto justify-center md:justify-start">
                    <div class="p-2 bg-blue-50 text-blue-600 border border-blue-100 rounded-lg shadow-sm">
                        <i class="fas fa-book-open w-6 h-6 flex items-center justify-center"></i>
                    </div>
                    <div class="text-left">
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Contenido</p>
                        <p class="text-lg font-bold text-slate-800">{course.totalLessons} Lecciones</p>
                    </div>
                </div>
        
                <div class="flex items-center gap-4 px-4 w-full md:w-auto justify-center md:justify-start">
                    <div class="p-2 bg-purple-50 text-purple-600 border border-purple-100 rounded-lg shadow-sm">
                        <i class="fas fa-layer-group w-6 h-6 flex items-center justify-center"></i>
                    </div>
                    <div class="text-left">
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Nivel</p>
                        <p class="text-lg font-bold text-slate-800">{course.level}</p>
                    </div>
                </div>
        
                <div class="flex items-center gap-4 px-4 w-full md:w-auto justify-center md:justify-start">
                    <div class="p-2 bg-orange-50 text-orange-600 border border-orange-100 rounded-lg shadow-sm">
                        <i class="fas fa-clock w-6 h-6 flex items-center justify-center"></i>
                    </div>
                    <div class="text-left">
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Duración</p>
                        <p class="text-lg font-bold text-slate-800">{course.duration}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <main id="temario" class="max-w-7xl mx-auto px-4 py-16 mt-10">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <div class="lg:col-span-2 space-y-12">
                
                <div class="rounded-3xl overflow-hidden shadow-2xl shadow-slate-200 h-64 md:h-96 border border-slate-100 relative">
                    {course.image_url ? (
                        <img src={course.image_url} alt={course.title} class="w-full h-full object-cover" />
                    ) : (
                        <div class="w-full h-full bg-slate-200 flex items-center justify-center text-slate-400">
                            <i class="fas fa-image text-6xl"></i>
                        </div>
                    )}
                </div>

                {/* Puntos de Aprendizaje - Solo se muestra si hay datos */}
                {course.learningPoints.length > 0 && (
                    <div>
                        <h3 class="text-2xl font-bold text-slate-900 mb-6">Lo que aprenderás:</h3>
                        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {course.learningPoints.map((point) => (
                                <li class="flex items-start gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100">
                                    <i class="fas fa-check-circle text-somno mt-1 shrink-0"></i>
                                    <span class="text-slate-700 text-sm md:text-base leading-relaxed font-medium">{point}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}

                <div class="prose prose-lg prose-slate max-w-none text-slate-600">
                    <p>{course.description}</p>
                </div>

                {/* Requisitos - Solo se muestra si hay datos */}
                {course.requirements.length > 0 && (
                    <div class="bg-blue-50/50 p-8 rounded-3xl border border-blue-100">
                        <h3 class="text-xl font-bold text-slate-900 mb-4">Requisitos previos:</h3>
                        <ul class="space-y-3 text-slate-600">
                            {course.requirements.map((req) => (
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0"></span>
                                    {req}
                                </li>
                            ))}
                        </ul>
                    </div>
                )}
            </div>

            <aside class="lg:sticky lg:top-24 h-fit space-y-8">
                <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-xl shadow-slate-100/50">
                    <h3 class="text-lg font-bold text-slate-900 mb-6">El curso incluye:</h3>
                    
                    <ul class="space-y-4 mb-8">
                        {features.map((item) => (
                        <li class="flex justify-between items-center text-sm group">
                            <div class="flex items-center gap-3 text-slate-500 font-medium group-hover:text-somno transition-colors">
                                {item.icon === 'level' && <i class="fas fa-layer-group w-5 text-center"></i>}
                                {item.icon === 'video' && <i class="fas fa-play-circle w-5 text-center"></i>}
                                {item.icon === 'clock' && <i class="fas fa-clock w-5 text-center"></i>}
                                {item.icon === 'cert' && <i class="fas fa-certificate w-5 text-center"></i>}
                                {item.icon === 'lang' && <i class="fas fa-globe w-5 text-center"></i>}
                                <span>{item.label}</span>
                            </div>
                            <span class="font-bold text-slate-800">{item.value}</span>
                        </li>
                        ))}
                    </ul>

                    <div class="border-t border-slate-100 pt-6">
                        <div class="flex items-end gap-2 mb-4">
                            <span class="text-4xl font-black text-slate-900">
                                {course.price === 0 ? 'Gratis' : `$${course.price}`}
                            </span>
                        </div>

                        {course.price === 0 ? (
                            <button 
                                id="btn-enroll"
                                data-course-id={course.id}
                                class="w-full py-4 bg-somno hover:bg-teal-600 text-white font-bold rounded-xl shadow-lg shadow-somno/30 transition-all hover:-translate-y-1 active:scale-95"
                            >
                                Comenzar Gratis
                            </button>
                        ) : (
                            <a 
                                href={`https://wa.me/529999999999?text=Hola, quiero inscribirme al curso: ${course.title}`} 
                                target="_blank"
                                class="block text-center w-full py-4 bg-green-500 hover:bg-green-600 text-white font-bold rounded-xl shadow-lg shadow-green-500/30 transition-all hover:-translate-y-1 active:scale-95"
                            >
                                <i class="fab fa-whatsapp mr-2"></i> Comprar Curso
                            </a>
                        )}
                    </div>
                </div>

                <div class="bg-slate-50 border border-slate-200 rounded-2xl p-5 flex items-center gap-4">
                    <div class="w-16 h-16 rounded-xl bg-slate-200 overflow-hidden shrink-0">
                        <img src={`https://ui-avatars.com/api/?name=${course.instructor_name}&background=0D9488&color=fff`} alt={course.instructor_name} class="w-full h-full object-cover" />
                    </div>
                    <div>
                        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-0.5">Instructor</p>
                        <h4 class="text-lg font-bold leading-tight text-slate-800">{course.instructor_name}</h4>
                    </div>
                </div>
            </aside>
        </div>
    </main>

    <section class="w-full bg-slate-50 py-16 px-4 border-t border-slate-200">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4">
                <div>
                    <h2 class="text-3xl font-bold text-slate-900 mb-2">Otros cursos de interés</h2>
                    <p class="text-slate-500">Amplía tu formación con estos programas recomendados.</p>
                </div>
                <a href="/cursos" class="bg-white border border-slate-200 hover:border-somno text-slate-600 hover:text-somno font-bold py-2.5 px-6 rounded-full transition-all shadow-sm text-sm">
                    Ver todos los cursos
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {relatedDbCourses?.map((related) => (
                    <a href={`/cursos/${related.slug}`} class="bg-white rounded-2xl overflow-hidden border border-slate-100 shadow-md hover:shadow-xl transition-all duration-300 group flex flex-col h-full">
                        <div class="h-48 overflow-hidden bg-slate-200">
                            {related.image_url && (
                                <img src={related.image_url} alt={related.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                            )}
                        </div>
                        <div class="p-6 flex-1 flex flex-col">
                            <span class="text-xs font-bold text-somno uppercase tracking-wider">{related.category || 'Curso Online'}</span>
                            <h3 class="text-lg font-bold text-slate-800 mt-2 mb-2 leading-tight group-hover:text-somno transition-colors">
                                {related.title}
                            </h3>
                            <div class="flex items-center justify-between mt-auto pt-4 text-sm text-slate-500">
                                <span><i class="fas fa-chalkboard-teacher mr-1"></i> {related.instructor_name}</span>
                                <span class="font-bold text-slate-900">{related.price === 0 ? 'Gratis' : `$${related.price}`}</span>
                            </div>
                        </div>
                    </a>
                ))}
                
                {(!relatedDbCourses || relatedDbCourses.length === 0) && (
                    <div class="col-span-full text-center py-10 opacity-50">
                        <p>No hay otros cursos disponibles por el momento.</p>
                    </div>
                )}
            </div>
        </div>
    </section>
</Layout>

<script>
    // Buscamos el botón de inscripción gratuita
    const btnEnroll = document.getElementById('btn-enroll');

    if (btnEnroll) {
        btnEnroll.addEventListener('click', async () => {
            // 1. Feedback visual inmediato
            const originalText = btnEnroll.innerText;
            btnEnroll.innerText = "Inscribiendo...";
            btnEnroll.setAttribute('disabled', 'true');
            btnEnroll.classList.add('opacity-75', 'cursor-not-allowed');

            try {
                // 2. Obtener el ID del curso desde el atributo data
                const courseId = btnEnroll.dataset.courseId;

                // 3. Llamar a la API de inscripción
                const response = await fetch('/api/enroll', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ courseId })
                });

                const data = await response.json();

                if (response.ok) {
                    // 4. ¡Éxito! Redirigir al aula
                    btnEnroll.innerText = "¡Listo! Redirigiendo...";
                    btnEnroll.classList.remove('bg-somno', 'hover:bg-teal-600');
                    btnEnroll.classList.add('bg-green-500');
                    
                    setTimeout(() => {
                        window.location.href = `/aula/${data.slug || window.location.pathname.split('/').pop()}`;
                    }, 1000);
                } else {
                    // 5. Manejar errores (ej: No logueado)
                    if (response.status === 401) {
                        window.location.href = '/login'; // O a donde tengas tu login
                        return;
                    }
                    throw new Error(data.error || 'Error desconocido');
                }

            } catch (error) {
                console.error(error);
                alert('Hubo un problema al inscribirte. Por favor intenta de nuevo.');
                
                // Restaurar botón
                btnEnroll.innerText = originalText;
                btnEnroll.removeAttribute('disabled');
                btnEnroll.classList.remove('opacity-75', 'cursor-not-allowed');
            }
        });
    }
</script>