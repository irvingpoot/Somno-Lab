---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { supabase } from '../../lib/supabase';
import { isUserAdmin } from '../../lib/isAdmin';

const { userId } = Astro.locals.auth();
if (!isUserAdmin(userId)) return Astro.redirect('/');

// Obtener lista de cursos para el select
const { data: courses } = await supabase.from('courses').select('id, title, price').order('created_at');
---

<Layout title="Gestión de Alumnos - SomnoLab">
    <Navbar />

    <main class="min-h-screen bg-slate-50 py-20 px-4">
        <div class="max-w-2xl mx-auto">
            
            <div class="flex items-center gap-4 mb-8">
                <a href="/dashboard" class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-slate-400 hover:text-somno shadow-sm">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <h1 class="text-3xl font-black text-slate-800">Inscripción Manual</h1>
            </div>

            <div class="bg-white p-8 rounded-2xl shadow-xl border border-slate-200">
                <p class="mb-6 text-slate-500 text-sm">
                    Usa esta herramienta para dar acceso a un curso de pago después de confirmar la transferencia bancaria.
                </p>

                <form id="enroll-form" class="space-y-6">
                    
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">ID del Usuario (Clerk ID)</label>
                        <input 
                            type="text" 
                            id="user-id" 
                            required 
                            placeholder="user_2bNg..."
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno font-mono text-sm"
                        />
                        <p class="text-xs text-slate-400 mt-1">Copia el ID desde el panel de Clerk > Users</p>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Seleccionar Curso</label>
                        <select id="course-select" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno bg-white">
                            {courses?.map(c => (
                                <option value={c.id}>
                                    {c.title} — {c.price > 0 ? `$${c.price}` : 'Gratis'}
                                </option>
                            ))}
                        </select>
                    </div>

                    <button type="submit" id="btn-enroll" class="w-full bg-somno hover:bg-teal-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-somno/20 transition-all">
                        Dar Acceso al Curso
                    </button>

                </form>
            </div>
        </div>
    </main>
</Layout>

<script>
    const form = document.getElementById('enroll-form');
    const btn = document.getElementById('btn-enroll');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const targetUserId = (document.getElementById('user-id') as HTMLInputElement).value;
        const courseId = (document.getElementById('course-select') as HTMLSelectElement).value;

        const originalText = btn.innerText;
        btn.innerText = "Procesando...";
        btn.setAttribute('disabled', 'true');

        try {
            const res = await fetch('/api/admin/manual-enroll', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ targetUserId, courseId })
            });

            const data = await res.json();

            if (res.ok) {
                alert('✅ ¡Usuario inscrito correctamente!');
                (document.getElementById('user-id') as HTMLInputElement).value = ''; // Limpiar campo
            } else {
                alert('❌ Error: ' + data.error);
            }
        } catch (err) {
            alert('❌ Error de conexión');
        } finally {
            btn.innerText = originalText;
            btn.removeAttribute('disabled');
        }
    });
</script>