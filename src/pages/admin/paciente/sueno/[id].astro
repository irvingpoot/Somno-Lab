                                        <div class="bg-gray-100/80 p-3 rounded-lg text-center">
                                            <span class="text-xs text-gray-500 block">Ronquidos</span>
                                            <span class="text-xl font-bold text-gray-700">{promedios?.ronquidos ?? '—'}</span>
                                        </div>
                                    </div>
                                    <div class="grid grid-cols-5 gap-2 text-center">
                                        <div class="bg-gray-50/50 rounded py-1.5"><span class="text-[10px] text-gray-500 block">IAI</span><span class="text-sm font-mono text-gray-600">{promedios?.iai ?? '—'}</span></div>
                                        <div class="bg-gray-50/50 rounded py-1.5"><span class="text-[10px] text-gray-500 block">IAO</span><span class="text-sm font-mono text-gray-600">{promedios?.iao ?? '—'}</span></div>
                                        <div class="bg-gray-50/50 rounded py-1.5"><span class="text-[10px] text-gray-500 block">IAC</span><span class="text-sm font-mono text-gray-600">{promedios?.iac ?? '—'}</span></div>
                                        <div class="bg-gray-50/50 rounded py-1.5"><span class="text-[10px] text-gray-500 block">IAM</span><span class="text-sm font-mono text-gray-600">{promedios?.iam ?? '—'}</span></div>
                                        <div class="bg-gray-50/50 rounded py-1.5"><span class="text-[10px] text-gray-500 block">IDO</span><span class="text-sm font-mono text-gray-600">{promedios?.ido ?? '—'}</span></div>
                                    </div>
                                </div>

                                <div class="mt-4">
                                    <h5 class="text-xs font-bold text-gray-500 mb-3 border-b border-gray-200 pb-1 uppercase">Oximetría y Pulso</h5>
                                    <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
                                        <div class="flex items-center justify-between bg-emerald-500/5 border border-emerald-500/10 p-3 rounded-lg">
                                            <span class="text-xs text-emerald-400 font-bold">Sat. Promedio</span>
                                            <span class="text-xl font-bold text-gray-900">{promedios?.saturacion_promedio != null ? `${promedios.saturacion_promedio}%` : '—'}</span>
                                        </div>
                                        <div class="flex items-center justify-between bg-rose-500/5 border border-rose-500/10 p-3 rounded-lg">
                                            <span class="text-xs text-rose-400 font-bold">Pulso Promedio</span>
                                            <span class="text-xl font-bold text-gray-900">{promedios?.pulso_promedio != null ? `${promedios.pulso_promedio}` : '—'} <span class="text-xs text-gray-500">bpm</span></span>
                                        </div>
                                        <div class="flex flex-col justify-center bg-gray-50/80 p-2 rounded-lg text-center">
                                            <span class="text-[10px] text-gray-500 uppercase">Sat &lt; 90%</span>
                                            <div class="flex justify-center gap-3 text-sm font-mono">
                                                <span class="text-gray-900">{promedios?.sat_90_min != null ? `${promedios.sat_90_min} min` : '—'}</span>
                                                <span class="text-gray-600">|</span>
                                                <span class="text-gray-900">{promedios?.sat_90_porc != null ? `${promedios.sat_90_porc}%` : '—'}</span>
                                            </div>
                                        </div>
                                        <div class="flex flex-col justify-center bg-gray-50/80 p-2 rounded-lg text-center">
                                            <span class="text-[10px] text-gray-500 uppercase">Sat &lt; 85%</span>
                                            <div class="flex justify-center gap-3 text-sm font-mono">
                                                <span class="text-gray-900">{promedios?.sat_85_min != null ? `${promedios.sat_85_min} min` : '—'}</span>
                                                <span class="text-gray-600">|</span>
                                                <span class="text-gray-900">{promedios?.sat_85_porc != null ? `${promedios.sat_85_porc}%` : '—'}</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    ) : (
                        <div class="flex flex-col items-center justify-center py-10 text-center border-2 border-dashed border-gray-300 rounded-2xl">
                            <div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                            </div>
