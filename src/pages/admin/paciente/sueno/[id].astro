    #dynamic-nav[data-state='floating'] {
        @apply max-w-[680px] mt-2;
        
        @apply bg-white/95 border-gray-300;
        @apply rounded-full;
        @apply shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)];
    }

    .nav-link {
        @apply px-4 py-2 text-[11px] font-bold uppercase tracking-wider text-gray-500;
