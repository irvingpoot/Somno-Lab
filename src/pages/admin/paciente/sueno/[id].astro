                                        <td class="py-2 text-center font-mono text-emerald-200">{extra.puntaje_post ?? "-"}</td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </InfoCard>
            </section>

            <section id="reporte-resultados" class="mb-10 animate-fade-in-up delay-100">
