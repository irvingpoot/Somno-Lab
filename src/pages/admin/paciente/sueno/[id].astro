            <button onclick="document.getElementById('modal-detalle-noche').close()" class="text-gray-500 hover:text-gray-900 transition-colors cursor-pointer text-2xl leading-none">&times;</button>
        </div>
        <div id="contenido-detalle-noche" class="p-6 space-y-6 overflow-y-auto max-h-[80vh] custom-scrollbar"></div>
