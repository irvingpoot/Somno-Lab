                                    <div class="text-center bg-white/90 rounded-lg p-3 border border-gray-200 border-l border-l-gray-700/50">
                                        <span class="text-xs text-gray-500 uppercase font-bold tracking-wider block mb-1">Dur. Evaluación</span>
                                        <p class="text-lg text-gray-900 font-mono">{promedios?.duracion_evaluacion ?? '—'}</p>
                                    </div>
                                </div>

                                <div>
                                    <h5 class="text-xs font-bold text-gray-500 mb-3 border-b border-gray-200 pb-1 uppercase">Análisis Respiratorio</h5>
