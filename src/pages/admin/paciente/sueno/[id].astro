                                        <td class="py-2 text-center font-mono text-emerald-200">{paciente[`${score}_post`] ?? "-"}</td>
                                    </tr>
                                ))}
                                {paciente.pacientes_puntajes_extra && paciente.pacientes_puntajes_extra.map((extra: any) => (
                                    <tr class="bg-somno/5">
                                        <td class="py-2 pr-4 font-medium text-somno-dark">{extra.nombre_prueba} <span class="text-[10px] text-gray-500 uppercase">(Extra)</span></td>
                                        <td class="py-2 text-center font-mono text-somno">{extra.puntaje_pre ?? "-"}</td>
