    <dialog id="modal-psqi-estudio" class="m-auto bg-white border border-purple-300 rounded-2xl p-6 shadow-2xl backdrop:backdrop-blur-sm w-full max-w-sm text-center">
        <div class="mb-4 text-purple-400 flex justify-center">
