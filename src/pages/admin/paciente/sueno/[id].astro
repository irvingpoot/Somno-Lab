                                            <span class="text-xl font-bold text-gray-700">{promedios?.indice_apneas ?? '—'}</span>
                                        </div>
                                        <div class="bg-gray-100/80 p-3 rounded-lg text-center">
                                            <span class="text-xs text-gray-500 block">Índ. Hipopnea</span>
                                            <span class="text-xl font-bold text-gray-700">{promedios?.indice_hipopnea ?? '—'}</span>
