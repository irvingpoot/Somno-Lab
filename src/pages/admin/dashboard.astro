<style>
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-infinite-scroll {
        animation: scroll 20s linear infinite;
    }
    .animate-infinite-scroll:hover {
        animation-play-state: paused;
    }
</style>

<script>
    const panel = document.getElementById('panel-tareas');
    const aside = document.getElementById('aside-tareas');

    if (!panel || !aside) throw new Error('Aside tareas: elementos no encontrados');

    let abierto = false;
    let hoverTimeout: ReturnType<typeof setTimeout> | null = null;

    const abrir = () => {
        panel.classList.remove('translate-x-full');
        abierto = true;
    };

    const cerrar = () => {
        panel.classList.add('translate-x-full');
        abierto = false;
    };

    panel.addEventListener('click', () => {
        abierto ? cerrar() : abrir();
    });

    aside.addEventListener('mouseenter', () => {
        if (hoverTimeout) clearTimeout(hoverTimeout);
        abrir();
    });

    aside.addEventListener('mouseleave', () => {
        hoverTimeout = setTimeout(() => {
            cerrar();
        }, 300);
    });

    document.addEventListener('click', (e) => {
        if (abierto && !aside.contains(e.target as Node)) {
            cerrar();
        }
    });
</script>