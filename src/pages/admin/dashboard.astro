---
/**
 * @file dashboard.astro
 * @description Panel de control principal del usuario.
 *
 * La lógica de acceso a datos vive en: src/services/dashboard.service.ts
 */

import Layout from "../../layouts/Layout.astro"
import { UserButton } from "@clerk/astro/components";
import SystemUpdates from "../../components/SystemUpdate.astro";
import PatientTypeModal from "../../components/PatientTypeModal.astro";
import {
    getCitasHoy,
    getNotificaciones,
    marcarTodasLeidas,
} from "../../services/dashboard.service";
import {
    getTareasDeUsuario,
    completarTarea,
} from "../../services/lista-pendientes.service";
import RightArrow from "../../components/icons/RightArrow.astro";

const user          = await Astro.locals.currentUser();
const nombreUsuario = user?.firstName || user?.username || "Usuario";
const nombreCompleto = user
    ? `${user.firstName || ""} ${user.lastName || ""}`.trim() || user.username || ""
    : "";


if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const action   = formData.get("action");

        if (action === "mark_all_read") {
            await marcarTodasLeidas();
        }

        if (action === "completar_tarea_sidebar") {
            const idTarea = formData.get("id_tarea") as string;
            await completarTarea(idTarea, nombreCompleto as string);
        }
    } catch (e) {
        console.error("Error marcando notificaciones:", e);
    }
    return Astro.redirect(Astro.url.href);
}

const [agenda, notificaciones, tareasUsuario] = await Promise.all([
    getCitasHoy(),
    getNotificaciones(),
    getTareasDeUsuario(nombreCompleto as string),
]);

const { totalCitasHoy, cantidadPendientes, estadoAgenda, proximaHora, proximaNombre } = agenda;
const hayNotificaciones = notificaciones.length > 0;

const fechaHoyTexto = new Date().toLocaleDateString("es-MX", {
    timeZone: "America/Merida",
    weekday: "long", year: "numeric", month: "long", day: "numeric",
});
---

<Layout title="Dashboard | SomnoLab" showFooter={false}>
    <main class="max-w-6xl mx-auto pt-10 pb-20 px-6">

        <div class="relative mb-8 pb-1">
            <div class="absolute -top-10 -left-10 w-64 h-64 bg-somno/10 rounded-full blur-[80px] pointer-events-none mix-blend-multiply"></div>

            <div class="relative z-10 flex flex-col md:flex-row justify-between items-end gap-6 mb-5">
                
                <div class="space-y-3">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-somno/10 border border-somno/30 text-somno text-[10px] font-bold uppercase tracking-widest w-fit backdrop-blur-sm">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-somno-light"></span>
                        </span>
                        Panel de Control - SomnoLab
                    </div>

                    <h1 class="text-5xl md:text-6xl font-black text-gray-900 tracking-tight leading-tight">
                        Hola, <br class="md:hidden" />
                        <span class="relative inline-block">
                            <span class="absolute inset-0 bg-linear-to-r from-somno to-emerald-500 blur-xl opacity-30 select-none" aria-hidden="true">{nombreUsuario}</span>
                            <span class="relative text-transparent bg-clip-text bg-linear-to-r from-somno via-somno-light to-somno-dark filter drop-shadow-sm">
                                {nombreUsuario} <UserButton />
                            </span>
                        </span>
                    </h1>

                    <p class="text-gray-500 text-lg font-light max-w-lg leading-relaxed">
                        Que bueno tenerte de vuelta. ¿Qué quieres hacer hoy?
                    </p>
                </div>

                <div class="hidden md:flex flex-col items-end gap-4 text-right">
                    
                    <div class="flex items-center gap-4">
                        <div class="relative group z-50">
                            <button class="relative p-3 text-gray-500 hover:text-gray-900 transition-colors rounded-full bg-gray-100/80 border border-gray-200 hover:bg-gray-200 hover:border-gray-300">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                                </svg>
                                {hayNotificaciones && (
                                    <span class="absolute top-2 right-2.5 flex h-2.5 w-2.5">
                                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
                                    </span>
                                )}
                            </button>

                            <div class="absolute right-0 mt-2 w-80 bg-white border border-gray-300 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 origin-top-right transform">
                                
                                <div class="p-3 border-b border-gray-200 flex justify-between items-center">
                                    <div class="flex items-center gap-2">
                                        <h4 class="text-sm font-bold text-gray-900">Actividad</h4>
                                        {hayNotificaciones && <span class="text-[10px] bg-somno text-white px-2 py-0.5 rounded-full">{notificaciones.length}</span>}
                                    </div>

                                    {hayNotificaciones && (
                                        <form method="POST">
                                            <input type="hidden" name="action" value="mark_all_read" />
                                            <button type="submit" class="text-[10px] font-bold text-somno hover:text-gray-900 transition-colors uppercase tracking-wider cursor-pointer">
                                                Marcar todo como visto
                                            </button>
                                        </form>
                                    )}
                                </div>
                                <div class="max-h-64 overflow-y-auto py-1 custom-scrollbar text-left">
                                    {hayNotificaciones ? (
                                        notificaciones.map((notif) => (
                                            <a 
                                                href={`/admin/paciente/${notif.pacientes?.tipo_paciente || 'sueno'}/${notif.pacientes?.id}?marcar_leido=${notif.id}#evaluacion`}
                                                class="block px-4 py-3 hover:bg-gray-100/50 border-b border-gray-200/80 last:border-0 transition-colors"
                                            >
                                                <div class="flex justify-between items-start mb-1">
                                                    <span class="text-sm font-bold text-somno-dark capitalize">{notif.pacientes?.nombre || 'Paciente'}</span>
                                                    <span class="text-[10px] text-gray-500">{new Date(notif.updated_at).toLocaleDateString('es-MX', {day: '2-digit', month:'short'})}</span>
                                                </div>
                                                <p class="text-xs text-gray-600">
                                                    Respondió: <span class="font-mono text-purple-600 uppercase">{notif.cuestionario}</span>
                                                </p>
                                            </a>
                                        ))
                                    ) : (
                                        <div class="px-4 py-6 text-center text-gray-500 text-xs italic">
                                            No hay nuevas respuestas.
                                        </div>
                                    )}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="group min-w-full flex items-center gap-4 px-5 py-4 rounded-2xl bg-white/70 border border-gray-200 backdrop-blur-md hover:border-gray-300 hover:bg-gray-100/60 transition-all duration-300 shadow-lg shadow-gray-300/40">
                        <div class="bg-gray-200 p-2.5 rounded-xl group-hover:bg-somno/15 group-hover:text-somno transition-colors text-gray-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div class="text-left">
                            <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Fecha Actual</p>
                            <p class="text-base font-semibold text-somno capitalize">{fechaHoyTexto}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="absolute bottom-0 left-0 w-full h-px bg-linear-to-r from-transparent via-gray-200 to-transparent mt-8"></div>
        </div>

        <div class="mb-10 animate-fade-in-up">
            {totalCitasHoy > 0 ? (
                <div class={`relative overflow-hidden rounded-2xl border p-6 flex flex-col md:flex-row items-center justify-between gap-6 shadow-lg transition-all duration-500 ${
                    estadoAgenda === 'completado' 
                        ? 'bg-linear-to-r from-emerald-50/80 to-teal-50/80 border-emerald-500/30 shadow-emerald-900/10' 
                        : 'bg-linear-to-r from-somno/10 to-somno-light/10 border-somno/40 shadow-somno/10'
                }`}>
                    
                    <div class={`absolute top-0 left-0 w-full h-full pattern-grid-lg pointer-events-none ${
                        estadoAgenda === 'completado' ? 'bg-emerald-50/50' : 'bg-somno-light/5'
                    }`}></div>
                    <div class={`absolute -left-4 -top-4 w-24 h-24 rounded-full blur-2xl ${
                        estadoAgenda === 'completado' ? 'bg-emerald-500/20' : 'bg-somno/20'
                    }`}></div>

                    <div class="relative z-10 flex items-center gap-5">
                        <div class="relative">
                            <div class={`w-16 h-16 rounded-2xl flex items-center justify-center shadow-lg transition-colors ${
                                estadoAgenda === 'completado' ? 'bg-emerald-600 shadow-emerald-600/40' : 'bg-somno shadow-somno/30'
                            }`}>
                                <span class="text-3xl font-extrabold text-gray-900">
                                    {estadoAgenda === 'completado' ? '✓' : cantidadPendientes}
                                </span>
                            </div>
                            {estadoAgenda === 'pendiente' && (
                                <div class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 border-2 border-white rounded-full animate-pulse"></div>
                            )}
                        </div>
                        
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 mb-1">Agenda de Hoy</h3>
                            <p class={`text-sm ${estadoAgenda === 'completado' ? 'text-emerald-200' : 'text-somno'}`}>
                                {estadoAgenda === 'completado' 
                                    ? `¡Excelente trabajo! Has atendido a tus ${totalCitasHoy} pacientes.` 
                                    : cantidadPendientes === 1 
                                        ? `Te queda 1 paciente esperando atención.` 
                                        : `Te quedan ${cantidadPendientes} pacientes por atender hoy.`
                                }
                            </p>
                            
                            <div class={`mt-2 inline-flex items-center gap-2 px-3 py-1 rounded-lg border text-xs transition-colors ${
                                estadoAgenda === 'completado' 
                                    ? 'bg-emerald-50 border-emerald-300 text-emerald-300'
                                    : 'bg-somno/10 border-somno/40 text-somno-dark'
                            }`}>
                                {estadoAgenda === 'completado' ? (
                                    <>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                        Agenda Completada
                                    </>
                                ) : (
                                    <>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                        Siguiente: <span class="font-bold text-gray-900">{proximaHora}</span> - {proximaNombre}
                                    </>
                                )}
                            </div>
                        </div>
                    </div>

                    <div class="relative z-5 w-full md:w-auto">
                        <a href="/admin/citas" class={`flex items-center justify-center gap-2 w-full md:w-auto px-6 py-3 text-white font-bold rounded-xl transition-all shadow-lg group ${
                            estadoAgenda === 'completado' 
                                ? 'bg-emerald-600 hover:bg-emerald-500 hover:shadow-emerald-500/25' 
                                : 'bg-somno hover:bg-somno-light hover:shadow-somno/25'
                        }`}>
                            Ver Agenda
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                            </svg>
                        </a>
                    </div>
                </div>
            ) : (
                <div class="relative overflow-hidden rounded-2xl bg-gray-100/60 border border-gray-200 p-6 flex flex-col md:flex-row items-center justify-between gap-4">
                    <div class="flex items-center gap-5">
                        <div class="w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900">Todo al día</h3>
                            <p class="text-gray-500 text-sm">No hay citas programadas para hoy, {fechaHoyTexto}.</p>
                        </div>
                    </div>
                    
                    <a href="/admin/nueva-cita" class="px-5 py-2.5 bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm font-medium rounded-lg transition-colors border border-gray-300">
                        Agendar Cita
                    </a>
                </div>
            )}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[180px]">

            <a href="/admin/citas" class="group relative bg-linear-to-br from-white to-gray-50 border border-gray-200/80 rounded-3xl p-8 overflow-hidden hover:border-purple-500/50 transition-all duration-300 hover:shadow-2xl hover:shadow-purple-900/20 hover:scale-[1.01]">
                <div class="absolute top-0 right-0 w-64 h-64 bg-purple-600/20 rounded-full blur-3xl -mr-16 -mt-16 transition-all group-hover:bg-purple-600/30"></div>
                
                <div class="relative z-10 h-full flex flex-col justify-between">
                    <div class="flex justify-between items-start">
                        <div class="p-3 bg-purple-500/20 rounded-2xl text-purple-600 group-hover:text-gray-900 group-hover:bg-purple-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" /></svg>
                        </div>
                        <span class="px-3 py-1 bg-gray-100/50 rounded-full text-xs font-medium text-gray-500 border border-gray-100 group-hover:border-purple-500/30 transition-colors">Gestión de Citas</span>
                    </div>
                    <div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-1 group-hover:translate-x-1 transition-transform">Agenda</h3>
                        <p class="text-gray-500 group-hover:text-purple-200 transition-colors">Visualizar calendario y citas pendientes</p>
                    </div>
                </div>
            </a>

            <a href="/admin/pendientes/lista-pendientes" class="group relative bg-linear-to-br from-white to-gray-50 border border-gray-200/80 rounded-3xl p-6 overflow-hidden hover:border-lime-500/50 transition-all duration-300 hover:shadow-2xl hover:shadow-lime-900/20 hover:scale-[1.01]">
                <div class="absolute top-0 right-0 w-32 h-32 bg-lime-500/10 rounded-full blur-2xl -mr-8 -mt-8 transition-all group-hover:bg-lime-500/20"></div>
                
                <div class="relative z-10 h-full flex flex-col justify-between">
                    <div class="flex justify-between items-start">
                        <div class="p-2.5 bg-lime-500/20 rounded-xl text-lime-600 group-hover:text-gray-900 group-hover:bg-lime-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-checklist"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9.615 20h-2.615a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h8a2 2 0 0 1 2 2v8" /><path d="M14 19l2 2l4 -4" /><path d="M9 8h4" /><path d="M9 12h2" /></svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 group-hover:text-lime-700 transition-colors">Tareas pendientes</h3>
                        <p class="text-xs text-gray-500 mt-1">Gestionar las tareas pendientes por hacer</p>
                    </div>
                </div>
            </a>

            <a href="/admin/lista" class="group relative md:row-span-2 bg-linear-to-br from-white to-gray-50 border border-gray-200/80 rounded-3xl p-8 overflow-hidden hover:border-somno/50 transition-all duration-300 hover:shadow-2xl hover:shadow-somno/15 hover:scale-[1.01]">
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-somno/10 rounded-full blur-3xl -ml-16 -mb-16 transition-all group-hover:bg-somno/15"></div>
                
                <div class="relative z-10 h-full flex flex-col justify-between">
                    <div class="p-3 w-fit bg-somno/20 rounded-2xl text-somno-dark group-hover:text-gray-900 group-hover:bg-somno-light transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
                    </div>
                    
                    <div class="mt-10">
                        <h3 class="text-3xl font-bold text-gray-900 mb-2 group-hover:translate-x-1 transition-transform">Pacientes</h3>
                        <p class="text-gray-500 text-sm leading-relaxed mb-4 group-hover:text-somno transition-colors">
                            Acceso directo a la base de datos completa de pacientes y expedientes clínicos.
                        </p>
                        <div class="flex items-center text-somno text-sm font-bold uppercase tracking-wider group-hover:text-somno-dark">
                            Ver lista <span class="group-hover:translate-x-1 transition-transform"><RightArrow class="size-5" /></span>
                        </div>
                    </div>
                </div>
            </a>

            <button onclick="document.getElementById('modal-tipo-paciente').showModal()" class="w-full text-left group relative bg-linear-to-br from-white to-gray-50 border border-gray-200/80 rounded-3xl p-6 overflow-hidden hover:border-emerald-500/50 transition-all duration-300 hover:shadow-2xl hover:shadow-emerald-900/20 hover:scale-[1.01] cursor-pointer">
                <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-full blur-2xl -mr-8 -mt-8 transition-all group-hover:bg-emerald-500/20"></div>
                <div class="relative z-10 h-full flex flex-col justify-between">
                    <div class="flex justify-between items-start">
                        <div class="p-2.5 bg-emerald-500/20 rounded-xl text-emerald-600 group-hover:text-gray-900 group-hover:bg-emerald-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-1.409-4.22a-2.25 2.25 0 0 1 3.423 3.42 2.25 2.25 0 0 1-3.423-3.42ZM6.75 2.25a.75.75 0 0 1 .75.75v.75h3a.75.75 0 0 1 0 1.5h-3v.75a.75.75 0 0 1-1.5 0v-.75H3a.75.75 0 0 1 0-1.5h3V3a.75.75 0 0 1 .75-.75Z" />
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 group-hover:text-emerald-700 transition-colors">Nuevo Paciente</h3>
                        <p class="text-xs text-gray-500 mt-1">Registrar ingreso</p>
                    </div>
                </div>
            </button>

            <a href="/admin/nueva-cita" class="group relative bg-linear-to-br from-white to-gray-50 border border-gray-200/80 rounded-3xl p-6 overflow-hidden hover:border-pink-500/50 transition-all duration-300 hover:shadow-2xl hover:shadow-pink-900/20 hover:scale-[1.01]">
                <div class="absolute top-0 right-0 w-32 h-32 bg-pink-500/10 rounded-full blur-2xl -mr-8 -mt-8 transition-all group-hover:bg-pink-500/20"></div>
                
                <div class="relative z-10 h-full flex flex-col justify-between">
                    <div class="flex justify-between items-start">
                        <div class="p-2.5 bg-pink-500/20 rounded-xl text-pink-600 group-hover:text-gray-900 group-hover:bg-pink-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 group-hover:text-pink-600 transition-colors">Agendar Cita</h3>
                        <p class="text-xs text-gray-500 mt-1">Crear nueva cita</p>
                    </div>
                </div>
            </a>

            <a href="/admin/feedback" hidden class="group relative md:row-span-2 bg-linear-to-br from-white to-gray-50 border border-gray-200/80 rounded-3xl p-6 overflow-hidden hover:border-amber-500/50 transition-all duration-300 hover:shadow-2xl hover:shadow-amber-900/20 hover:scale-[1.01]">
