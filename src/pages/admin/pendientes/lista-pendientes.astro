---
/**
 * @file pendientes.astro
 * @description Módulo de tareas y pendientes del laboratorio.
 *
 * La lógica de acceso a datos vive en: src/services/pendientes.service.ts
 */

import Layout from "../../../layouts/Layout.astro"
import ReturnButton from "../../../components/ReturnButton.astro"
import { clerkClient } from "@clerk/astro/server"
import { getTareasPendientes, crearTarea, completarTarea } from "../../../services/lista-pendientes.service"

const currentUser = await Astro.locals.currentUser();
const nombreCreador = currentUser
    ? `${currentUser.firstName || ""} ${currentUser.lastName || ""}`.trim() || currentUser.username
    : "Sistema";

const userList = await clerkClient(Astro).users.getUserList();

const listaPersonal: string[] = [];
const mapaAvatares: Record<string, string> = {};

userList.data.forEach(u => {
    const nombre = `${u.firstName || ""} ${u.lastName || ""}`.trim() || u.username;
    if (nombre) {
        listaPersonal.push(nombre);
        mapaAvatares[nombre] = u.imageUrl;
    }
});

if (Astro.request.method === "POST") {
    try {
        const data   = await Astro.request.formData();
        const accion = data.get("accion");

        if (accion === "crear_tarea") {
            await crearTarea({
                titulo:      data.get("titulo")      as string,
                descripcion: data.get("descripcion") as string,
                responsable: data.get("responsable") as string,
                creadoPor:   nombreCreador as string,
            });
        }

        if (accion === "completar_tarea") {
            const idTarea = data.get("id_tarea") as string; 
            await completarTarea(idTarea, nombreCreador as string);
        }

    } catch (error) {
        console.error("Error procesando tarea:", error);
    }

    return Astro.redirect("/admin/pendientes/lista-pendientes");
}

const tareas = await getTareasPendientes();

const getInitials = (name: string) => {
    if (!name) return "?";
    const words = name.trim().split(" ");
    if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
    return name.substring(0, 2).toUpperCase();
};

const formatCorto = (fechaStr: string) => {
    if (!fechaStr) return "";
    return new Date(fechaStr).toLocaleDateString("es-MX", { month: "short", day: "numeric" });
};
---

<Layout title="Pendientes | SomnoLab" showFooter={false}>
    <ReturnButton href="/admin/dashboard" text="Volver al dashboard" />
    
    <main class="max-w-7xl mx-auto pt-8 pb-20 px-4">
        <div class="flex flex-col justify-center items-center mb-8 gap-6 border-b border-white/10 pb-6">
            <div class="max-w-7xl mx-auto mb-3">
                <div class="absolute -top-10 -left-10 w-64 h-64 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>
                <h1 class="max-md:max-w-xs max-md:pt-10 max-lg:max-w-xl text-4xl md:text-6xl font-extrabold text-balance text-center">Tareas <span class="bg-linear-to-r from-somno to-somno-light bg-clip-text text-transparent drop-shadow-[0_0_15px_rgba(59,130,246,0.5)]">pendientes</span></h1>
                <p class=" pt-5 text-lg text-gray-400 text-center">
                    Gestiona, asigna y da seguimiento a las actividades diarias del laboratorio.
                </p>
            </div>
            
            <div class="flex items-center gap-4">
                <a href="/admin/pendientes/historial-pendientes" class="bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium py-3 px-4 rounded-xl flex items-center gap-2 border border-gray-700 transition-all hover:scale-105">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                    <span class="hidden md:inline text-sm">Ver Historial</span>
                </a>
                
                <button onclick="document.getElementById('modal-nueva-tarea').showModal()" class="bg-somno hover:bg-somno-light text-white font-bold py-3 px-6 rounded-xl flex items-center gap-2 shadow-lg shadow-somno/20 transition-all hover:scale-105 cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                    <span class="hidden md:inline">Nueva Tarea</span>
                </button>
            </div>
        </div>

        {tareas.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {tareas.map((tarea) => (
                    <div class="bg-white border border-slate-200 rounded-2xl p-5 hover:bg-slate-50 hover:border-somno-light transition-all duration-300 shadow-sm hover:shadow-md flex flex-col h-full relative group hover:-translate-y-1">
                        
                        <div class="flex justify-between items-start mb-4 gap-4">
                            <h3 class="text-lg font-bold text-slate-800 leading-snug group-hover:text-somno-dark transition-colors">
                                {tarea.titulo}
                            </h3>

                            <span class="shrink-0 bg-amber-100 text-amber-600 border border-amber-200 text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full flex items-center gap-1.5 shadow-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                                Pendiente
                            </span>
                        </div>

                        <p class="text-slate-500 text-sm mb-6 grow text-pretty whitespace-pre-wrap 
                                line-clamp-3 group-hover:line-clamp-none transition-all">
                            {tarea.descripcion || "Sin descripción adicional."}
                        </p>

                        <div class="flex items-center justify-between mt-auto mb-5 pt-4 border-t border-slate-200">
                            
                            <div class="flex flex-col gap-1.5">
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">
                                    Asignado a
                                </span>

                                <div class="flex items-center gap-2">
                                    {mapaAvatares[tarea.responsable] ? (
                                        <img 
                                            src={mapaAvatares[tarea.responsable]} 
                                            alt={`Avatar de ${tarea.responsable}`} 
                                            class="w-7 h-7 rounded-full object-cover shadow-sm ring-2 ring-white"
                                            loading="lazy"
                                        />
                                    ) : (
                                        <div class="w-7 h-7 rounded-full bg-linear-to-br 
                                                    from-somno to-somno-light 
                                                    flex items-center justify-center text-white text-[10px] font-bold shadow-sm">
                                            {getInitials(tarea.responsable)}
                                        </div>
                                    )}
                                    <span class="text-sm font-medium text-slate-700">
                                        {tarea.responsable}
                                    </span>
                                </div>
                            </div>

                            <div class="flex flex-col items-end gap-1.5 text-right">
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">
                                    Creado el
                                </span>

                                <div class="flex items-center gap-1.5 text-slate-500 bg-slate-100 px-2 py-1 rounded-md border border-slate-200">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                    </svg>
                                    <span class="text-xs font-medium">
                                        {formatCorto(tarea.creado_el)}
                                    </span>
                                </div>
                            </div>
                        </div>

                        <form method="POST" class="mt-auto m-0">
                            <input type="hidden" name="accion" value="completar_tarea" />
                            <input type="hidden" name="id_tarea" value={tarea.id} />

                            <button type="submit" class="w-full bg-white border border-slate-300 text-slate-600 cursor-pointer hover:text-white hover:bg-somno hover:border-somno font-bold text-sm py-2.5 rounded-xl flex items-center justify-center gap-2 transition-all group/btn">
                                <div class="w-5 h-5 rounded-full border-2 border-slate-400 group-hover/btn:border-white group-hover/btn:bg-white/20 flex items-center justify-center transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 opacity-0 group-hover/btn:opacity-100 group-hover/btn:text-white transition-all scale-50 group-hover/btn:scale-100">
                                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                                    </svg>
                                </div>

                                Marcar como Completada
                            </button>
                        </form>
                    </div>
                ))}
            </div>
        ) : (
            <div class="flex flex-col items-center justify-center py-20 text-center border-2 border-dashed border-gray-800 rounded-3xl">
                <div class="bg-gray-300/50 p-4 rounded-full mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-somno"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" /></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-1">Todo al día</h3>
                <p class="text-gray-500 text-sm">No hay tareas pendientes en este momento.</p>
            </div>
        )}
    </main>

    <dialog id="modal-nueva-tarea" class="m-auto bg-white border border-slate-200 rounded-3xl shadow-xl backdrop:backdrop-blur-xl w-full max-w-lg text-left p-0 overflow-hidden outline-none">

        <div class="relative bg-slate-50 p-6 border-b border-slate-200 flex justify-between items-center">
            <h3 class="text-2xl font-extrabold text-slate-800">Nueva Tarea</h3>
            
            <button onclick="document.getElementById('modal-nueva-tarea').close()" 
                type="button" 
                class="text-slate-400 hover:text-somno-dark 
                    bg-white hover:bg-somno-light/20 
                    p-2 rounded-full transition-colors">
                ✕
            </button>
        </div>
        
        <form method="POST" class="p-6 space-y-5">
            <input type="hidden" name="accion" value="crear_tarea" />
            
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                    Título de la tarea <span class="text-red-500">*</span>
                </label>

                <input type="text" name="titulo" required
                    placeholder="Ej: Llamar al paciente Juan Pérez"
                    class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 
                        text-slate-800 placeholder-slate-400
                        focus:outline-none focus:border-somno 
                        focus:ring-2 focus:ring-somno-light/30
                        transition-all" />
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                    Responsable <span class="text-red-500">*</span>
                </label>

                <div class="relative group">
                    <select name="responsable" required
                        class="appearance-none w-full bg-white border border-slate-300 rounded-xl pl-4 pr-10 py-3 
                            text-slate-800 
                            focus:outline-none focus:border-somno 
                            focus:ring-2 focus:ring-somno-light/30
                            transition-all cursor-pointer">
                        
                        <option value="" disabled selected>Selecciona a quién asignar</option>
                        {listaPersonal.map((persona) => (
                            <option value={persona}>{persona}</option>
                        ))}
                    </select>

                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none 
                                text-slate-400 group-hover:text-somno transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                        </svg>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                    Descripción o Detalles
                </label>

                <textarea name="descripcion" rows="3"
                    placeholder="Agrega notas, teléfonos o instrucciones específicas..."
                    class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 
                        text-slate-800 placeholder-slate-400
                        focus:outline-none focus:border-somno 
                        focus:ring-2 focus:ring-somno-light/30
                        transition-all resize-none"></textarea>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-200">
                
                <button type="button"
                    onclick="document.getElementById('modal-nueva-tarea').close()"
                    class="px-5 py-2.5 rounded-xl text-sm font-bold 
                        text-slate-500 hover:text-slate-700 
                        hover:bg-slate-100 transition-colors cursor-pointer">
                    Cancelar
                </button>

                <button type="submit"
                    class="px-5 py-2.5 rounded-xl text-sm font-bold 
                        bg-somno hover:bg-somno-dark 
                        text-white shadow-md 
                        transition-all hover:scale-105 flex items-center gap-2 cursor-pointer">
                    
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>

                    Crear Tarea
                </button>
            </div>
        </form>
    </dialog>
</Layout>

<style>
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
    }
    dialog[open] {
        animation: modalFadeIn 0.2s ease-out;
    }
    @keyframes modalFadeIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>