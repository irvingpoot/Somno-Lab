---
/**
 * @file historial-tareas.astro
 * @description Tabla de auditoría para tareas completadas.
 */

import Layout from "../../../layouts/Layout.astro"
import ReturnButton from "../../../components/ReturnButton.astro"
import { createClient } from "@supabase/supabase-js"

const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.SUPABASE_KEY
);

const { data: tareasCompletadas, error } = await supabase
    .from('tareas_pendientes')
    .select('*')
    .eq('estado', 'completada')
    .order('completado_el', { ascending: false });

if (error) console.error("Error fetching historial:", error);

const formatFecha = (isoString: string) => {
    if (!isoString) return 'Fecha desconocida';
    return new Date(isoString).toLocaleString('es-MX', { 
        timeZone: 'America/Merida',
        year: 'numeric', month: 'short', day: 'numeric',
        hour: '2-digit', minute: '2-digit'
    });
};
---

<Layout title="Historial de Tareas | SomnoLab" showFooter={false}>
    <ReturnButton href="/admin/pendientes/lista-pendientes" text="Volver a Pendientes" />
    
    <main class="max-w-7xl mx-auto pt-8 pb-20 px-4">
        
        <!-- Header -->
        <div class="mb-8 border-b border-slate-200 pb-6">
            <h1 class="text-4xl font-extrabold text-slate-800">Historial de Tareas</h1>
            <p class="text-slate-500 mt-2 text-sm">
                Registro de todas las tareas operativas marcadas como completadas.
            </p>
        </div>

        {tareasCompletadas && tareasCompletadas.length > 0 ? (
            
            <!-- Tabla container -->
            <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse min-w-225">
                        
                        <!-- Head -->
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="px-8 py-4 text-slate-500 font-semibold text-sm uppercase tracking-wider">Tarea</th>
                                <th class="px-6 py-4 text-slate-500 font-semibold text-sm uppercase tracking-wider hidden lg:table-cell">Descripción</th>
                                <th class="px-6 py-4 text-slate-500 font-semibold text-sm uppercase tracking-wider hidden md:table-cell">Responsable</th>
                                <th class="px-6 py-4 text-slate-500 font-semibold text-sm uppercase tracking-wider hidden lg:table-cell">Creada Por</th>
                                <th class="px-6 py-4 text-somno font-semibold text-sm uppercase tracking-wider">Cerrada Por</th>
                                <th class="px-6 py-4 text-slate-500 font-semibold text-sm uppercase tracking-wider text-right">Fecha de Cierre</th>
                            </tr>
                        </thead>
                        
                        <!-- Body -->
                        <tbody>
                            {tareasCompletadas.map((tarea) => (
                                <tr class="group hover:bg-slate-50 transition-colors relative">
                                    
                                    <td class="px-8 py-5 align-middle">
                                        <div class="absolute bottom-0 left-0 right-0 h-px bg-slate-200 group-hover:bg-somno-light transition-all"></div>
                                        
                                        <span class="text-slate-800 font-medium text-lg group-hover:text-somno-dark transition-colors">
                                            {tarea.titulo}
                                        </span>
                                    </td>

                                    <td class="px-6 py-5 align-middle hidden md:table-cell">
                                        {tarea.descripcion && (
                                            <p class="text-slate-500 truncate">{tarea.descripcion}</p>
                                        )}
                                    </td>
                                    
                                    <td class="px-6 py-5 align-middle hidden md:table-cell">
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-slate-100 text-slate-600 border border-slate-200">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                                            </svg>
                                            {tarea.responsable}
                                        </span>
                                    </td>

                                    <td class="px-6 py-5 text-slate-500 align-middle hidden lg:table-cell text-sm">
                                        {tarea.creado_por}
                                    </td>

                                    <td class="px-6 py-5 align-middle">
                                        <span class="text-somno-dark font-medium">
                                            {tarea.completado_por || 'Desconocido'}
                                        </span>
                                    </td>

                                    <td class="px-6 py-5 text-slate-500 font-mono text-sm align-middle text-right">
                                        {formatFecha(tarea.completado_el)}
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>

        ) : (
            
            <!-- Empty state -->
            <div class="flex flex-col items-center justify-center py-20 text-center 
                        border-2 border-dashed border-slate-200 rounded-3xl">

                <div class="bg-somno-light/20 border border-somno-light/30 p-4 rounded-full mb-4">
                    
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-somno">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                </div>

                <h3 class="text-xl font-bold text-slate-700 mb-1">
                    Historial Limpio
                </h3>

                <p class="text-slate-500 text-sm">
                    Aún no se ha completado ninguna tarea.
                </p>
            </div>
        )}
    </main>
</Layout>