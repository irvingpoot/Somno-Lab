---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import { supabase } from '../../../lib/supabase';

// 1. LÓGICA DEL SERVIDOR (Frontmatter)
let errorMessage = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        
        // Obtenemos los valores
        const title = formData.get("title")?.toString();
        const slug = formData.get("slug")?.toString();
        const price = formData.get("price")?.toString() || "0";
        const description = formData.get("description")?.toString() || "Curso especializado de SomnoLab.";
        const level = formData.get("level")?.toString() || "Principiante";
        const category = formData.get("category")?.toString() || "Salud y Bienestar";
        const image_url = formData.get("image_url")?.toString() || "https://placehold.co/600x400/teal/white?text=Nuevo+Curso";

        if (!title || !slug) {
            throw new Error("El título y el slug son obligatorios.");
        }

        // Insertamos el curso COMPLETO
        const { data, error } = await supabase
            .from('courses')
            .insert([
                { 
                    title, 
                    slug,
                    price: parseFloat(price),
                    description,
                    level,
                    category,
                    image_url,
                    is_published: false,
                    // Arrays vacíos para que no den error en el frontend
                    learning_points: [],
                    requirements: []
                }
            ])
            .select()
            .single();

        if (error) throw error;

        // Éxito: Vamos a editar los módulos
        return Astro.redirect(`/admin/cursos/editar/${data.id}`);

    } catch (error) {
        if (error instanceof Error) {
            errorMessage = error.message;
        } else {
            errorMessage = "Ocurrió un error desconocido.";
        }
    }
}
---

<Layout title="Nuevo Curso - SomnoLab">
    <Navbar />
    
    <main class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-20">
        <div class="bg-white p-8 rounded-2xl shadow-xl border border-slate-200 w-full max-w-2xl">
            
            <div class="flex justify-between items-center mb-8 border-b border-slate-100 pb-4">
                <div>
                    <h1 class="text-2xl font-black text-slate-800">Crear Nuevo Curso</h1>
                    <p class="text-slate-500 text-sm">Configura la información básica de la Landing Page.</p>
                </div>
                <a href="/admin/cursos" class="text-slate-400 hover:text-slate-600 w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100 transition-colors">
                    <i class="fas fa-times"></i>
                </a>
            </div>

            {errorMessage && (
                <div class="mb-6 p-4 bg-red-50 text-red-700 border border-red-200 rounded-xl text-sm font-medium flex items-center gap-2 animate-pulse">
                    <i class="fas fa-exclamation-circle"></i>
                    {errorMessage}
                </div>
            )}

            <form method="POST" class="space-y-6">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Título del Curso <span class="text-red-500">*</span></label>
                        <input 
                            type="text" 
                            name="title" 
                            id="title"
                            required
                            placeholder="Ej: Higiene del Sueño Avanzada"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno focus:ring-4 focus:ring-somno/10 outline-none transition-all font-bold text-slate-800"
                        />
                    </div>

                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">URL Amigable (Slug) <span class="text-red-500">*</span></label>
                        <div class="flex items-center">
                            <span class="bg-slate-50 border border-r-0 border-slate-200 text-slate-500 px-3 py-3 rounded-l-xl text-sm font-mono">/cursos/</span>
                            <input 
                                type="text" 
                                name="slug" 
                                id="slug"
                                required
                                readonly
                                class="w-full px-4 py-3 rounded-r-xl border border-slate-200 bg-slate-50 text-slate-600 font-mono text-sm focus:outline-none cursor-not-allowed"
                            />
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-slate-100">
                    
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Precio ($)</label>
                        <input 
                            type="number" 
                            name="price" 
                            placeholder="0" 
                            min="0"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno outline-none"
                        />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Categoría</label>
                        <select name="category" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno outline-none bg-white">
                            <option value="Salud y Bienestar">Salud y Bienestar</option>
                            <option value="Medicina del Sueño">Medicina del Sueño</option>
                            <option value="Psicología">Psicología</option>
                            <option value="Nutrición">Nutrición</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Nivel</label>
                        <select name="level" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno outline-none bg-white">
                            <option value="Principiante">Principiante</option>
                            <option value="Intermedio">Intermedio</option>
                            <option value="Avanzado">Avanzado</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">URL Imagen Portada</label>
                        <input 
                            type="text" 
                            name="image_url" 
                            placeholder="https://..." 
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno outline-none"
                        />
                    </div>

                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Descripción Corta</label>
                        <textarea 
                            name="description" 
                            rows="3" 
                            placeholder="Breve resumen de lo que el estudiante aprenderá..."
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-somno outline-none resize-none"
                        ></textarea>
                    </div>
                </div>

                <div class="pt-6">
                    <button type="submit" class="w-full bg-somno hover:bg-teal-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-somno/20 transition-all transform hover:scale-[1.02] flex items-center justify-center gap-2">
                        <span>Crear Curso y Editar Contenido</span>
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </form>
        </div>
    </main>
</Layout>

<script>
    const titleInput = document.getElementById('title');
    const slugInput = document.getElementById('slug');

    titleInput?.addEventListener('input', (e) => {
        // @ts-ignore
        const val = e.target.value;
        const slug = val
            .toLowerCase()
            .trim()
            .replace(/[^\w\s-]/g, '')
            .replace(/[\s_-]+/g, '-')
            .replace(/^-+|-+$/g, '');
        
        // @ts-ignore
        if (slugInput) slugInput.value = slug;
    });
</script>