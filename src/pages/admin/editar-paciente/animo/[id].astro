                                <label class="flex items-center gap-2"><input type="radio" name="te" value="si" checked={p.te === 'si'} class="accent-somno trigger-condicional" data-target="div_te"> Sí</label>
                                <label class="flex items-center gap-2"><input type="radio" name="te" value="no" checked={p.te !== 'si'} class="accent-somno trigger-condicional" data-target="div_te"> No</label>
