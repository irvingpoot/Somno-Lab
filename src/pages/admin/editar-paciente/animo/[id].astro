                                <label class="flex items-center gap-2"><input type="radio" name="alcohol" value="si" checked={p.alcohol === 'si'} class="accent-somno trigger-condicional" data-target="div_alcohol"> Sí</label>
                                <label class="flex items-center gap-2"><input type="radio" name="alcohol" value="no" checked={p.alcohol !== 'si'} class="accent-somno trigger-condicional" data-target="div_alcohol"> No</label>
                            </div>
                            <div id="div_alcohol" class={p.alcohol === 'si' ? "mt-3" : "hidden mt-3"}>
