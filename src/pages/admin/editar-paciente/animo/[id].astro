                                                </div>

                                                <div class="flex justify-between md:col-span-12 freq-container pt-2 border-t border-gray-200/60">
                                                    <div>
                                                        <label class="block text-[10px] uppercase font-bold text-somno mb-2">Frecuencia (Horario)</label>
                                                        <input type="hidden" name="farmacos_frecuencias" class="input-frecuencia-real" value={frecuenciaStr}/>
                                                        
                                                        <div class="flex gap-4">
                                                            {['Mañana', 'Tarde', 'Noche'].map(opt => (
                                                                <label class="flex items-center gap-2 cursor-pointer group/chk">
                                                                    <input 
                                                                        type="checkbox" 
                                                                        value={opt} 
                                                                        checked={frecuenciaStr.includes(opt)} 
                                                                        class="chk-freq accent-somno w-4 h-4 rounded cursor-pointer"
                                                                    />
                                                                    <span class="text-sm text-gray-400 group-hover/chk:text-gray-900 transition-colors">{opt}</span>
                                                                </label>
                                                            ))}
                                                        </div>
                                                    </div>
                                                    <div class="flex items-center">
                                                        <button type="button" class="btn-remove-farmaco w-7 text-gray-500 text-center hover:text-red-400 opacity-0 group-hover:opacity-100 transition-all cursor-pointer bg-gray-100 p-1.5 rounded-md hover:bg-red-50 shrink-0" title="Eliminar fila">
                                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    );
