                                                    <input type="text" name="farmacos_dosis" value={dosis} placeholder="Ej. 20mg" class="w-full bg-transparent border-b border-gray-300 text-gray-900 text-sm focus:border-somno outline-none py-1 placeholder-gray-400"/>
                                                </div>

                                                <div class="md:col-span-8">
                                                    <label class="block text-[10px] uppercase font-bold text-somno mb-1">Motivo / Diagnóstico</label>
                                                    <input type="text" name="farmacos_motivos" value={motivo} placeholder="Ej. Depresión" class="w-full bg-transparent border-b border-gray-300 text-gray-900 text-sm focus:border-somno outline-none py-1 placeholder-gray-400"/>
                                                </div>
                                                <div class="md:col-span-4">
