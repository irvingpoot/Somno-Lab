    <dialog id="modal-dia" class="m-auto bg-white border border-gray-300 rounded-3xl shadow-xl backdrop:backdrop-blur-xl w-full max-w-lg text-left p-0 overflow-hidden outline-none">
        <div class="relative bg-gray-50/60 p-6 border-b border-gray-200">
            <div class="relative z-10 flex justify-between items-start">
                <div>
                    <p class="text-xs text-somno font-bold uppercase tracking-wider mb-1" id="modal-mes-anio"></p>
                    <div class="flex items-center gap-3">
                        <h3 class="text-3xl font-extrabold text-gray-900">Día <span id="modal-dia-num" class="text-somno"></span></h3>
                        <span id="badge-inhabil" class="hidden bg-red-900/50 text-red-400 border border-red-500/30 text-[10px] px-2 py-0.5 rounded-full uppercase tracking-wider font-bold">Inhábil</span>
                    </div>
                </div>
                <button onclick="document.getElementById('modal-dia').close()" class="text-gray-400 hover:text-gray-900 bg-gray-100/60 hover:bg-gray-200/60 p-2 rounded-full transition-colors">✕</button>
            </div>
        </div>

        <div class="p-6 max-h-[50vh] overflow-y-auto" id="modal-lista-citas"></div>

        <div class="p-4 bg-gray-50/80 border-t border-gray-200/60 flex justify-center gap-x-3">
            <form method="POST" class="m-0">
                <input type="hidden" name="accion" value="toggle_inhabil" />
                <input type="hidden" name="fecha" id="modal-fecha-inhabil" value="" />
                <input type="hidden" name="es_inhabil" id="modal-es-inhabil" value="" />
                <button type="submit" id="btn-toggle-inhabil" class="text-xs font-bold transition-colors uppercase tracking-widest py-2 flex items-center gap-2"></button>
            </form>
            <a id="btn-agendar-modal" href="/admin/nueva-cita" class="text-xs font-bold text-gray-400 hover:text-somno flex items-center gap-2 transition-colors uppercase tracking-widest py-2">
                <span class="text-lg leading-none">+</span> Agendar cita
            </a>
        </div>
    </dialog>
</Layout>

<style>
    #modal-lista-citas::-webkit-scrollbar { width: 4px; }
    #modal-lista-citas::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }
    
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
    }
    dialog[open] {
        animation: modalFadeIn 0.2s ease-out;
    }
    @keyframes modalFadeIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

<script define:vars={{ displayMonth, currentYear, currentMonth, diasInhabilesArray: Array.from(diasInhabilesSet) }}>
    window.mesNombre = displayMonth;
    window.anio = currentYear;
    window.mesNumero = currentMonth;
    window.diasInhabiles = new Set(diasInhabilesArray);

    window.openDayModal = (day) => {
        const modal = document.getElementById('modal-dia');
        const listaContainer = document.getElementById('modal-lista-citas');
        const btnAgendar = document.getElementById('btn-agendar-modal');
        
        document.getElementById('modal-dia-num').textContent = day;
        document.getElementById('modal-mes-anio').textContent = `${window.mesNombre} ${window.anio}`;
        
        const m = String(window.mesNumero + 1).padStart(2, '0');
        const d = String(day).padStart(2, '0');
        const fechaISO = `${window.anio}-${m}-${d}`;
        const isInhabil = window.diasInhabiles.has(fechaISO);

        if (btnAgendar) {
            if (isInhabil) {
                btnAgendar.classList.add('hidden');
                btnAgendar.classList.remove('flex');
            } else {
                btnAgendar.classList.remove('hidden');
                btnAgendar.classList.add('flex');
                btnAgendar.href = `/admin/nueva-cita?fecha=${fechaISO}`;
            }
        }
        
        document.getElementById('modal-fecha-inhabil').value = fechaISO;
        document.getElementById('modal-es-inhabil').value = isInhabil;
        
        const badgeInhabil = document.getElementById('badge-inhabil');
        const btnToggle = document.getElementById('btn-toggle-inhabil');
        
        if (isInhabil) {
            badgeInhabil.classList.remove('hidden');
            btnToggle.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                Habilitar Día
            `;
            btnToggle.className = 'text-xs font-bold text-emerald-500 hover:text-emerald-400 transition-colors uppercase tracking-widest py-2 flex items-center gap-1.5';
        } else {
            badgeInhabil.classList.add('hidden');
            btnToggle.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                Marcar como Inhábil
            `;
            btnToggle.className = 'text-xs font-bold text-gray-400 hover:text-red-400 transition-colors uppercase tracking-widest py-2 flex items-center gap-1.5 cursor-pointer';
        }

        const tarjetasGuardadas = document.querySelector(`#citas-store div[data-day="${day}"]`);
        
        if (tarjetasGuardadas && tarjetasGuardadas.children.length > 0) {
            listaContainer.innerHTML = tarjetasGuardadas.outerHTML;
            listaContainer.firstElementChild.classList.remove('hidden');
            listaContainer.firstElementChild.classList.add('block');
        } else {
            listaContainer.innerHTML = `
                <div class="flex flex-col items-center justify-center py-12 text-gray-400 border-2 border-dashed border-gray-200 rounded-2xl">
                    <p class="font-medium">${isInhabil ? 'Día bloqueado' : 'Sin citas programadas'}</p>
                    <p class="text-xs mt-1 opacity-60">${isInhabil ? 'No se deberían agendar citas' : 'Tiempo libre disponible'}</p>
                </div>
            `;
        }

        modal.showModal();
    }
</script>