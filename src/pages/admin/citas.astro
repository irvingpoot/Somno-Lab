                            </div>
                        </div>

                        <span class="text-gray-600 mr-1">/</span>

                        <div class="relative group">
                            <select name="year" onchange="this.form.submit()" class="appearance-none bg-transparent text-gray-900 font-bold text-sm cursor-pointer focus:outline-none hover:text-somno transition-colors px-4 py-1">
                                {yearsRange.map((y) => (
                                    <option value={y} selected={y === currentYear} class="bg-white text-gray-600">
                                        {y}
                                    </option>
                                ))}
                            </select>
                            <div class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400 group-hover:text-somno">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
                            </div>
                        </div>
                    </form>

                    <a href={nextLink} class="w-10 h-10 flex items-center justify-center text-gray-400 hover:text-gray-900 hover:bg-gray-200/60 rounded-full transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    </a>
                </div>

                <a href="/admin/nueva-cita" class="bg-somno hover:bg-somno-light text-white font-medium w-10 h-10 md:w-auto md:px-4 rounded-full flex items-center justify-center gap-2 shadow-lg shadow-somno/20 transition-all hover:scale-105">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                    <span class="hidden md:inline text-sm">Agendar nueva cita</span>
                </a>
            </div>
        </div>

        <div class="space-y-4">
            
            <div class="grid grid-cols-7 text-center">
                {["Dom", "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb"].map((day, i) => (
                    <div class={`text-xs font-bold uppercase tracking-widest py-2 ${i === 0 || i === 6 ? 'text-somno/70' : 'text-gray-500'}`}>
                        {day}
                    </div>
                ))}
            </div>

            <div class="grid grid-cols-7 gap-2 md:gap-4 auto-rows-[140px]">
                
                {Array.from({ length: firstDayOfMonth }).map(() => (
                    <div class="pointer-events-none"></div>
                ))}

                {Array.from({ length: daysInMonth }).map((_, i) => {
                    const dayNum   = i + 1;
                    const citasDia = citasPorDia.get(dayNum) || [];
                    const isToday  = dayNum === today.getDate() && currentMonth === today.getMonth() && currentYear === today.getFullYear();
                    
                    const m        = String(currentMonth + 1).padStart(2, "0");
                    const d        = String(dayNum).padStart(2, "0");
                    const fechaISO = `${currentYear}-${m}-${d}`;
                    const isInhabil = diasInhabilesSet.has(fechaISO);
                    
                    return (
                        <div 
                            class={`group relative p-3 rounded-2xl border transition-all duration-300 cursor-pointer flex flex-col justify-between overflow-hidden
                                ${isInhabil 
                                    ? 'bg-red-50/80 border-red-200/60 shadow-[inset_0_0_20px_rgba(220,38,38,0.05)] hover:border-red-300/60' 
                                    : isToday 
                                        ? 'bg-somno/10 border-somno shadow-[0_0_20px_rgba(62,140,177,0.15)]' 
                                        : 'bg-gray-100/60 border-gray-100 hover:bg-gray-200/60 hover:border-gray-300/60 hover:scale-[1.02] hover:shadow-xl'
                                }
                            `}
                            onclick={`window.openDayModal(${dayNum})`}
                        >
                            <div class="flex justify-between items-start z-10">
                                <span class={`text-lg font-bold leading-none ${isInhabil ? 'text-red-400' : isToday ? 'text-somno' : 'text-gray-400 group-hover:text-gray-900'}`}>
                                    {dayNum}
                                </span>
                                
                                {isInhabil && (
                                    <span class="text-[9px] uppercase font-bold text-red-400 tracking-widest border border-red-500/30 px-1.5 rounded-sm">Inhábil</span>
                                )}

                                {!isInhabil && citasDia.length > 0 && (
                                    <span class="flex items-center justify-center h-5 min-w-5 px-1 text-[10px] font-bold bg-white text-gray-900 rounded-full shadow-sm">
                                        {citasDia.length}
                                    </span>
                                )}
                            </div>

                            <div class="space-y-1 mt-2 z-10">
                                {citasDia.slice(0, 2).map((cita) => (
                                    <div class={`flex items-center gap-1.5 text-[10px] rounded px-1.5 py-1 backdrop-blur-sm border truncate 
                                        ${isInhabil ? 'bg-red-50 border-red-200/60 text-red-400/80' : 'bg-white/70 border-gray-100 text-gray-600'}`}>
                                        <div class={`w-1.5 h-1.5 rounded-full shrink-0 ${
                                            cita.estado === 'completada' ? 'bg-emerald-400' : 
                                            cita.estado === 'cancelada'  ? 'bg-red-400'     : 'bg-amber-400'
                                        }`}></div>
                                        <span class="truncate opacity-90">{cita.nombre ? cita.nombre.split(' ')[0] : 'Cita'}</span>
                                    </div>
                                ))}
                                {citasDia.length > 2 && (
                                    <div class="text-[10px] text-center text-gray-400 font-medium group-hover:text-gray-600">+ {citasDia.length - 2} más</div>
                                )}
                            </div>
                            {isToday && !isInhabil && <div class="absolute bottom-0 inset-x-0 h-1 bg-somno-light"></div>}
                        </div>
                    );
                })}
            </div>
        </div>
    </main>

    <div id="citas-store" class="hidden" style="content-visibility: auto;">
        {Array.from(citasPorDia.entries()).map(([dia, citas]) => (
            <div data-day={dia} class="space-y-4">
                {citas.map((cita) => (
                    <CitaCard cita={cita} />
                ))}
            </div>
        ))}
    </div>

    <dialog id="modal-periodo" class="m-auto bg-white border border-gray-300 rounded-3xl shadow-xl backdrop:backdrop-blur-xl w-full max-w-md text-left p-0 overflow-hidden outline-none">
        <div class="relative bg-gray-50/60 p-6 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-xl font-extrabold text-gray-900">Gestionar días inhabiles</h3>
            <button onclick="document.getElementById('modal-periodo').close()" type="button" class="text-gray-400 hover:text-gray-900 bg-gray-100/60 hover:bg-gray-200/60 p-2 rounded-full transition-colors">✕</button>
        </div>
        
        <form method="POST" class="p-6 space-y-6">
            <input type="hidden" name="accion" value="procesar_periodo" />
            
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Acción a realizar</label>
                    
                    <div class="relative group">
                        <select name="tipo_operacion" class="appearance-none w-full bg-white border border-gray-300 rounded-xl pl-4 pr-10 py-3 text-gray-900 focus:outline-none focus:border-somno transition-colors cursor-pointer">
